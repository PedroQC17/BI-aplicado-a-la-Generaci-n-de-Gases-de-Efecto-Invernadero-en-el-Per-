  <step>
    <name>Compute Centroid</name>
    <type>ScriptValueMod</type>
    <description>Calcula lat/lon del centroide a partir de las coordenadas del poligono</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel/>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>compute_centroid</jsScript_name>
        <jsScript_script>var lat = null;
var lon = null;

if (coordinates != null &amp;&amp; coordinates !== 'null') {
    try {
        var str = typeof coordinates === 'string' ? coordinates : JSON.stringify(coordinates);
        // Extraer la primera coordenada valida usando regex: busca [numero, numero]
        // GeoJSON Polygon: [[[lon,lat],...]]  o MultiPolygon: [[[[lon,lat],...]]]
        var match = str.match(/\[(-?\d+\.?\d*)\s*,\s*(-?\d+\.?\d*)\]/);
        if (match) {
            lon = parseFloat(match[1]);
            lat = parseFloat(match[2]);
        }
    } catch(e) {
        lat = null;
        lon = null;
    }
}</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>lat</name>
        <rename>lat</rename>
        <type>Number</type>
        <length>14</length>
        <precision>8</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>lon</name>
        <rename>lon</rename>
        <type>Number</type>
        <length>14</length>
        <precision>8</precision>
        <replace>N</replace>
      </field>
    </fields>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>240</xloc>
      <yloc>80</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
