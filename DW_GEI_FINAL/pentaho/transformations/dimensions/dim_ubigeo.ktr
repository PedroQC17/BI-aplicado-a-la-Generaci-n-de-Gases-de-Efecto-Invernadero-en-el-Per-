    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>PostgreSQL 18</connection>
    <sql>    SELECT DISTINCT
      codigo_ubigeo,
      departamento,
      provincia,
      distrito,
      ROUND(lat::numeric, 6) AS lat,
      ROUND(lon::numeric, 6) AS lon,
      'Distrito' AS nivel_geografico,
      1 AS flag_detalle_geografico
    FROM staging.stg_gadm
    WHERE lat IS NOT NULL
      AND lon IS NOT NULL
      AND codigo_ubigeo IS NOT NULL</sql>
    <limit>0</limit>
    <lookup/>
