  <step>
    <name>CT puntos</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>PostgreSQL 18</connection>
    <sql>    SELECT DISTINCT
      g.codigo_ubigeo,
      g.departamento,
      g.provincia,
      g.distrito,
      ROUND(CAST(ct.lat AS numeric), 6) AS lat,
      ROUND(CAST(ct.lon AS numeric), 6) AS lon,
      'Punto' AS nivel_geografico,
      1 AS flag_detalle_geografico
    FROM staging.stg_climate_trace ct
    CROSS JOIN LATERAL (
      SELECT codigo_ubigeo, departamento, provincia, distrito, lat, lon
      FROM staging.stg_gadm
      WHERE lat IS NOT NULL AND lon IS NOT NULL
        AND codigo_ubigeo IS NOT NULL
      ORDER BY
        (lat::numeric - CAST(ct.lat AS numeric)) * (lat::numeric -
  CAST(ct.lat AS numeric)) +
        (lon::numeric - CAST(ct.lon AS numeric)) * (lon::numeric -
  CAST(ct.lon AS numeric))
      LIMIT 1
    ) g
    WHERE (ct.geometry_ref IS NULL OR ct.geometry_ref = '')
      AND ct.lat IS NOT NULL
      AND ct.lon IS NOT NULL</sql>
    <limit>0</limit>
    <lookup/>
